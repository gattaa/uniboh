{
  "name": "uniboh",
  "version": "1.0.0",
  "description": "MCP server for University of Bologna services: Virtuale (Moodle) APIs and corsi.unibo.it timetable/ICS export.",
  "main": "dist/server.js",
  "bin": {
    "uniboh-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unibo",
    "moodle",
    "virtuale",
    "timetable",
    "ics"
  ],
  "author": "gattaa",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "fetch-cookie": "^3.2.0",
    "playwright": "^1.61.1",
    "tough-cookie": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
